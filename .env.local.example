# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LinkedIn OAuth (configured in Supabase Auth dashboard)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Token encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key

# Paperclip integration (optional — enables auto-review tasks for Strategist)
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_KEY=your-paperclip-api-key
PAPERCLIP_COMPANY_ID=your-paperclip-company-id

# Waitlist form → Google Sheets (Apps Script web app URL)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-deployment-id/exec
